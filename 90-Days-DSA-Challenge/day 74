1784. Check if Binary String Has at Most One Segment of Ones

Topic - Mid Level, String, Weekly Contest 231

Code Implementation.
-----------------------------------------------------------------------
class Solution {
public:
    bool checkOnesSegment(string s) {
        int n = s.size();
        for(int i = 0; i < n; i++){
            if(s[i] == '0' && s[i+1] == '1'){
                return false;
            }
        }return true;
    }
};
